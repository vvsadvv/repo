PORT=3005
CLIENT_URL=http://localhost:5174
FRONTEND_URL=http://localhost:5174
REPOSITORY_PUBLIC_BASE_URL=http://localhost:5174

# Optional: external storage directories (when empty, backend/uploads is used)
REPOSITORY_UPLOADS_DIR=
REPOSITORY_XML_DIR=
REPOSITORY_MAX_UPLOAD_BYTES=52428800
REPOSITORY_REMOTE_DOWNLOAD_TIMEOUT_MS=15000

REPO_AUTH_DB_HOST=localhost
REPO_AUTH_DB_PORT=5432
REPO_AUTH_DB_NAME=repo_auth_system
REPO_AUTH_DB_USER=repo_user
REPO_AUTH_DB_PASSWORD=replace-with-strong-password
REPO_AUTH_DB_ADMIN_DB=postgres

REPOSITORY_DB_HOST=localhost
REPOSITORY_DB_PORT=5432
REPOSITORY_DB_NAME=repository_system
REPOSITORY_DB_USER=repo_user
REPOSITORY_DB_PASSWORD=replace-with-strong-password
REPOSITORY_DB_ADMIN_DB=postgres

REPOSITORY_JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=10m

# === EMAIL (Gmail SMTP) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_PROXY=

# IMPORTANT: use the same Gmail account for which app password was created
SMTP_USER=your-email@gmail.com
SMTP_PASS=replace-with-app-password
SMTP_FROM=your-email@gmail.com
SMTP_FROM_NAME=Репозиторий ФИЦ ЕГС РАС

SMTP_FALLBACK_ENABLED=true
SMTP_CONNECTION_TIMEOUT=15000
SMTP_GREETING_TIMEOUT=15000
SMTP_SOCKET_TIMEOUT=30000
SMTP_DNS_TIMEOUT=10000
SMTP_OPERATION_TIMEOUT=30000

# SMTP alternative example:
#SMTP_HOST=smtp.mail.ru
#SMTP_PORT=465
#SMTP_USER=user@mail.ru
#SMTP_PASS=replace-with-password
#SMTP_SECURE=true

CROSSREF_LOGIN_ID=
CROSSREF_LOGIN_PASSWORD=
REPOSITORY_DOI_DEPOSITOR_NAME=Repository System
REPOSITORY_DOI_DEPOSITOR_EMAIL=repository@gsras.ru

# Automatic Crossref confirmation mailbox watcher (POP3)
CROSSREF_POP3_ENABLED=true
CROSSREF_POP3_HOST=pop3.obn.gsras.ru
CROSSREF_POP3_PORT=110
CROSSREF_POP3_SECURE=false
CROSSREF_POP3_USER=skleminos
CROSSREF_POP3_PASSWORD=
CROSSREF_POP3_POLL_INTERVAL_MS=60000
CROSSREF_POP3_TIMEOUT_MS=15000
CROSSREF_POP3_SKIP_EXISTING_ON_START=true
CROSSREF_POP3_MAX_MESSAGES_PER_POLL=20
CROSSREF_POP3_DELETE_PROCESSED=false
